  },
  "dependencies": {
    "@remotion/cli": "4.0.459",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.459"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "typescript": "5.6.3"
  }
}
